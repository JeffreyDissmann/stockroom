# =============================================================================
# Stockroom — Docker self-host configuration
# =============================================================================
# Copy this to .env, edit, then run:
#   docker compose -f docker-compose.prod.yml up -d
#
# Required fields are marked REQUIRED. Everything else has a sensible default.
# Generate strong random values for the *_KEY / *_PASSWORD fields — don't
# ship the placeholders in this file to production.

# ----- App ------------------------------------------------------------------

APP_NAME=Stockroom
APP_ENV=production
APP_DEBUG=false

# Public URL — what users type in the browser. Include the scheme. If you put
# the app behind a reverse proxy that terminates TLS, set the https:// URL
# here; the app will generate links accordingly.
APP_URL=http://localhost:8080

# Host port the app container is published on. The container always listens
# on 8080 internally; this just selects the host-side binding.
APP_PORT=8080

# APP_KEY is auto-generated and persisted by the container — leave this line
# entirely commented out. The entrypoint stores the key in storage/.stockroom-app-key
# (a volume-mounted location), so it survives container recreation and you
# never have to manage it manually. Setting it here as an empty string
# *overrides* the persisted key on every restart and breaks every active
# session, so don't.
# APP_KEY=

# Default UI language. Users can override per account.
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Currency for the whole household (ISO 4217 + a formatting locale).
CURRENCY=EUR
CURRENCY_LOCALE=de-DE

# ----- First-boot admin (REQUIRED on the very first start) ------------------
# The entrypoint creates this user only if no users exist yet. Subsequent
# boots are no-ops, so you can safely leave these set — or clear them after
# the first successful login.

STOCKROOM_ADMIN_EMAIL=admin@example.com
STOCKROOM_ADMIN_PASSWORD=change-me-immediately
STOCKROOM_ADMIN_NAME=Admin

# ----- Database (Postgres, runs in compose) ---------------------------------

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=stockroom
DB_USERNAME=stockroom
# REQUIRED. Generate with: openssl rand -base64 24
DB_PASSWORD=

# ----- Search (Meilisearch, runs in compose) --------------------------------

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
# REQUIRED. Generate with: openssl rand -base64 32
MEILISEARCH_KEY=

# ----- Sessions / cache / queue (kept on the DB so no Redis needed) ---------

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=file

# ----- Mail (default is "log" — outgoing mail is written to the app log) ----
# Set up a real mailer if you want password-reset emails or AI assistant
# notifications by email.

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=Stockroom

# ----- Image search (optional) ----------------------------------------------
# Enables the "search for an image" button. Leave blank to disable.
BRAVE_SEARCH_KEY=

# ----- AI assistant (optional, off by default) ------------------------------
# Set AI_ENABLED=true and point OLLAMA_URL at an Ollama instance you operate
# (another container, a LAN box, a separate GPU host). The image deliberately
# does not bundle Ollama; model weights are too large for a default install.

AI_ENABLED=false
AI_PROVIDER=ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=
AI_CHAT_MODEL=ministral-3:8b
AI_CHAT_RESET_AFTER_HOURS=3
AI_CHAT_RETENTION_DAYS=3

# Semantic (hybrid) search vectors. Requires AI to be enabled and an
# embeddings model available on the AI provider.
SCOUT_HYBRID_EMBEDDER=
SCOUT_HYBRID_SEMANTIC_RATIO=0.5
AI_EMBEDDINGS_MODEL=bge-m3:567m
AI_EMBEDDINGS_DIMENSIONS=768
