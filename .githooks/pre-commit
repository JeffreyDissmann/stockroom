#!/usr/bin/env bash
#
# Stockroom — local pre-commit guard: staged frontend files must be
# Prettier-clean, so formatting drift can never accumulate again (the
# 2026-06-07 sweep had to reformat ~30 silently drifted files; this hook
# keeps that a one-off).
#
# Runs on the host (prettier lives in the bind-mounted node_modules), so
# it works even while the Sail stack is down — unlike pre-push, committing
# shouldn't require running containers.
#
# Skip with `git commit --no-verify` if you really need to (don't).

set -e

# Staged frontend files only — a partial stage is checked as it is on disk,
# which is close enough for a formatting gate. The generated Wayfinder tree
# is excluded (Prettier ignores it anyway; filtering avoids the invocation
# entirely for commits that only touch generated files).
staged=$(git diff --cached --name-only --diff-filter=ACMR -- \
    'resources/**/*.vue' 'resources/**/*.ts' 'resources/**/*.js' 'resources/**/*.css' \
    | grep -vE '^resources/js/(actions|routes|wayfinder)/' || true)

if [ -z "$staged" ]; then
    exit 0
fi

# shellcheck disable=SC2086
if ! npx prettier --check $staged; then
    echo ""
    echo "✗ Formatting drift in the staged files above."
    echo "  Fix with: npx prettier --write <files>  (or vendor/bin/sail npm run format), then re-stage."
    exit 1
fi
