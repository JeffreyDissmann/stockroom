APP_NAME=Stockroom
APP_ENV=local

# Seeded admin user (created/updated when running `php artisan db:seed`)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@stockroom.local
ADMIN_PASSWORD=password

# Currency for the whole household (ISO 4217 code + a formatting locale)
CURRENCY=EUR
CURRENCY_LOCALE=de-DE

# Brave Search image API key — enables "Search for an image" on items.
# Get one at https://brave.com/search/api/ (Image Search). Leave blank to disable.
BRAVE_SEARCH_KEY=

APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=stockroom
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI (Laravel AI SDK). Defaults to a local Ollama instance. To use a hosted
# provider, set AI_PROVIDER (e.g. openai) and that provider's key (e.g. OPENAI_API_KEY).
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_API_KEY=

# Chat assistant model (must support tool/function calling). Use the exact tag from
# `ollama list` (e.g. ministral-3:8b, qwen2.5:7b-instruct, llama3.1:8b).
AI_CHAT_MODEL=ministral-3:8b

# Semantic (hybrid) search. The app computes embeddings with the Laravel AI SDK
# (provider via AI_PROVIDER / default_for_embeddings; model below) and stores them
# in Meilisearch as "userProvided" vectors — Meilisearch never calls an embedder.
# Needs SCOUT_DRIVER=meilisearch. Leave SCOUT_HYBRID_EMBEDDER blank for pure
# keyword search. After enabling, run:
#   sail artisan scout:sync-index-settings && sail artisan scout:import "App\Models\Item"
SCOUT_HYBRID_EMBEDDER=
SCOUT_HYBRID_SEMANTIC_RATIO=0.5
# Embedding model + its vector size. The dimensions MUST match the model's
# actual output (bge-m3:567m via Ollama emits 768; nomic-embed-text is 768 too).
# bge-m3 is multilingual and needs no task prefixes.
AI_EMBEDDINGS_MODEL=bge-m3:567m
AI_EMBEDDINGS_DIMENSIONS=768
